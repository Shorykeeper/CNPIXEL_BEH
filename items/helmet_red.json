{
	"format_version": "1.16.100",
	"minecraft:item": {
		"description": {
			"identifier": "fam:helmet_red",
			"category": "abwshop"
		},
		"components": {
			"minecraft:creative_category": {
				"parent": "abwshop"
			},
			// 在此处定义物品纹理短名称
			"minecraft:icon": {
				"texture": "fam:helmet_red"
			},
			// 胸甲不需要堆叠
			"minecraft:max_stack_size": 1,
			"minecraft:enchantable": {
				"value": 10,
				"slot": "armor_head"
			},
			// 该物品给予玩家的护甲值
			"minecraft:armor": {
				"protection": 1
			},
			"minecraft:repairable": {
				"repair_items": [
					{
						"items": ["fam:helmet_red"],
						// 下面的这串Molang你无需理解，复制就行
						"repair_amount": "context.other->q.remaining_durability + 0.05 * context.other->q.max_durability"
					}
				]
			},
			// 将其可以被装备进胸甲槽
			"minecraft:wearable": {
				"dispensable": true,
				"slot": "slot.armor.head"
			},
			"minecraft:durability": {
				"max_durability": 200
			}
		}
	}
}
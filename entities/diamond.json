{
    "format_version": "1.17.0",
    "minecraft:entity": {
        "components": {
            "minecraft:collision_box": {
                "height": 0.1,
                "width": 0
            },
            "minecraft:damage_sensor": {
                "triggers": [
                    {
                        "deals_damage": false,
                        "on_damage": {
                            "filters": [
                                {
                                    "none_of": [
                                        {
                                            "subject": "damager",
                                            "test": "has_ability",
                                            "value": "mayfly"
                                        }
                                    ]
                                }
                            ]
                        }
                    }
                ]
            },
            "minecraft:health": {
                "max": 1,
                "value": 1
            },
            "minecraft:knockback_resistance": {
                "value": 1
            },
            "minecraft:nameable": {
                "allow_name_tag_renaming": true,
                "alwaysShow": true,
                "always_show": true
            },
            "minecraft:persistent": {

            },
            "minecraft:physics": {
                "has_collision": false,
                "has_gravity": false
            },
            "minecraft:timer": {
                "looping": true,
                "time": 1.0,
                "time_down_event": {
                    "event": "minecrafts:res_tick",
                    "target": "self"
                }
            },
            "minecraft:type_family": {
                "family": [
                    "diamond"
                ]
            },
            "minecraft:scale": { "value": 1.0 },  // 确保有合适的尺寸
            "minecraft:is_hidden_when_invisible": { "value": false },  // 防止隐藏
            "minecraft:pushable": { "is_pushable": false },  // 避免被推动
            "minecraft:push_through": { "value": 1 },  // 允许玩家穿过
            "minecraft:leashable": { "soft_distance": 0.0, "hard_distance": 0.0 }  // 防止被拴住
        },
        "description": {
            "identifier": "minecrafts:diamond_spawner",
            "is_experimental": false,
            "is_spawnable": false,
            "is_summonable": true
        },
        "events": {
            "minecraft:entity_spawned": {
                "sequence": [
                    {
                        "trigger": {
                            "event": "minecrafts:res_tick",
                            "target": "self"
                        }
                    }
                ]
            },
            "minecrafts:res_tick": {
                "trigger": {
                    "event": "res_tick",
                    "target": "self"
                }
            }
        }
    }
}
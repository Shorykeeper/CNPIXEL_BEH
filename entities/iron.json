{
    "format_version": "1.17.0",
    "minecraft:entity": {
        "components": {
            "minecraft:collision_box": {
                "height": 0.1,
                "width": 0
            },
            "minecraft:damage_sensor": {
                "triggers": [
                    {
                        "deals_damage": false,
                        "on_damage": {
                            "filters": [
                                {
                                    "none_of": [
                                        {
                                            "subject": "damager",
                                            "test": "has_ability",
                                            "value": "mayfly"
                                        }
                                    ]
                                }
                            ]
                        }
                    }
                ]
            },
            "minecraft:health": {
                "max": 1,
                "value": 1
            },
            "minecraft:knockback_resistance": {
                "value": 1
            },
            "minecraft:nameable": {
                "allow_name_tag_renaming": true,
                "alwaysShow": false,
                "always_show": true
            },
            "minecraft:persistent": {

            },
            "minecraft:physics": {
                "has_collision": false,
                "has_gravity": false
            },
            "minecraft:timer": {
                "looping": true,
                "time": 0.5,
                "time_down_event": {
                    "event": "minecrafts:res_tick",
                    "target": "self"
                }
            },
            "minecraft:type_family": {
                "family": [
                    "iron"
                ]
            }
        },
        "description": {
            "identifier": "minecrafts:iron_spawner",
            "is_experimental": false,
            "is_spawnable": false,
            "is_summonable": true,
            "runtime_identifier": "minecraft:snowball"
        },
        "events": {
            "minecraft:entity_spawned": {
                "sequence": [
                    {
                        "trigger": {
                            "event": "minecrafts:res_tick",
                            "target": "self"
                        }
                    }
                ]
            },
            "minecrafts:res_tick": {
                "trigger": {
                    "event": "res_tick",
                    "target": "self"
                }
            }
        }
    }
}